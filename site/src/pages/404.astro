---
import SimpleLayout from "../layouts/SimpleLayout.astro";

const title = "Page not found — PanicStation.org";
const description =
  "The requested PanicStation.org page could not be found. Browse the guide library or return to the homepage.";
---

<SimpleLayout
  title={title}
  socialTitle="Page not found"
  description={description}
  robots="noindex, follow"
>
  <main class="ps-not-found" data-pagefind-ignore>
    <section class="ps-not-found-card" aria-labelledby="ps-not-found-title">
      <div class="ps-not-found-status" aria-hidden="true">404</div>

      <div class="ps-not-found-icon" aria-hidden="true">
        <i class="fa-solid fa-location-dot"></i>
      </div>

      <h1 id="ps-not-found-title">That page is not here</h1>

      <p>
        The address may be mistyped, the page may have moved, or the guide may
        no longer be available. Known old guide addresses are redirected to
        their current versions automatically.
      </p>

      <nav class="ps-not-found-actions" aria-label="Page not found options">
        <a class="ps-not-found-action ps-not-found-action-primary" href="/">
          Go to the homepage
        </a>
        <a class="ps-not-found-action" href="/guides/">Browse all guides</a>
        <a class="ps-not-found-action" href="/uk/">UK guides</a>
        <a class="ps-not-found-action" href="/us/">USA guides</a>
      </nav>
    </section>
  </main>
</SimpleLayout>

<style>
  .ps-not-found{
    width: 100%;
    max-width: 820px;
    margin: 0 auto 40px;
  }

  .ps-not-found-card{
    position: relative;
    overflow: hidden;
    padding: clamp(28px, 5vw, 52px);
    border: 1px solid rgba(34, 75, 122, 0.14);
    border-radius: 18px;
    background:
      radial-gradient(circle at 32% 18%, #132f52 0%, #1b416d 42%, #224b7a 100%);
    color: #fff;
    text-align: center;
    box-shadow:
      0 1px 0 rgba(0,0,0,.02),
      0 14px 40px rgba(15, 23, 42, 0.10);
  }

  .ps-not-found-status{
    position: absolute;
    top: -28px;
    right: 18px;
    color: rgba(255,255,255,.07);
    font-size: clamp(110px, 24vw, 220px);
    line-height: 1;
    font-weight: 950;
    letter-spacing: -0.08em;
    pointer-events: none;
    user-select: none;
  }

  .ps-not-found-icon{
    position: relative;
    width: 58px;
    height: 58px;
    margin: 0 auto 18px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    background: rgba(255,255,255,.13);
    border: 1px solid rgba(255,255,255,.22);
    font-size: 23px;
  }

  .ps-not-found h1{
    position: relative;
    margin: 0 0 14px;
    font-size: clamp(26px, 4vw, 42px);
    line-height: 1.15;
    letter-spacing: -0.5px;
    font-weight: 900;
  }

  .ps-not-found p{
    position: relative;
    max-width: 620px;
    margin: 0 auto;
    color: rgba(255,255,255,.88);
    font-size: 16px;
    line-height: 1.7;
  }

  .ps-not-found-actions{
    position: relative;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-top: 26px;
  }

  .ps-not-found-action{
    min-height: 40px;
    padding: 10px 15px;
    border: 1px solid rgba(255,255,255,.38);
    border-radius: 999px;
    background: rgba(255,255,255,.08);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 850;
    line-height: 1;
    text-decoration: none;
  }

  .ps-not-found-action:hover{
    background: rgba(255,255,255,.16);
  }

  .ps-not-found-action-primary{
    background: #fff;
    border-color: #fff;
    color: #224b7a;
  }

  .ps-not-found-action-primary:hover{
    background: #f1f4f9;
  }

  .ps-not-found-action:focus{
    outline: none;
  }

  .ps-not-found-action:focus-visible{
    box-shadow: 0 0 0 3px rgba(255,255,255,.28);
  }

  @media (max-width: 520px){
    .ps-not-found-card{
      border-radius: 16px;
      padding: 28px 18px;
    }

    .ps-not-found-status{
      top: -8px;
      right: 8px;
      font-size: 118px;
    }

    .ps-not-found-actions{
      flex-direction: column;
      align-items: stretch;
    }

    .ps-not-found-action{
      width: 100%;
    }
  }
</style>
