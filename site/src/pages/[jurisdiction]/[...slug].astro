---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { CATEGORIES, CATEGORY_FULL } from "../../lib/categories";
import { buildGuideStructuredData } from "../../lib/structuredData";
import "../../styles/guides.css";

const enableAdsenseTest = import.meta.env.PUBLIC_ENABLE_ADSENSE_TEST === "1";

export async function getStaticPaths() {
  const guides = await getCollection("guides");

  return guides.map((entry) => {
    const parts = entry.slug.split("/");
    const jurisdiction = parts[0];
    const slugParts = parts.slice(1);

    return {
      params: { jurisdiction, slug: slugParts.join("/") },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const urlJurisdiction = (Astro.params.jurisdiction || "us").toLowerCase();
const fmJurisdiction = entry.data.jurisdiction === "USA" ? "us" : "uk";

const lastReviewedDisplay = new Date(`${entry.data.last_reviewed}T00:00:00Z`).toLocaleDateString("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
  timeZone: "UTC",
});

const guideLabel = entry.data.jurisdiction === "USA" ? "USA guide" : "UK guide";

const categoryEntry = CATEGORIES.find((category) => {
  return CATEGORY_FULL[category.key] === entry.data.category;
});

const breadcrumbJurisdictionLabel =
  entry.data.jurisdiction === "USA" ? "USA guides" : "UK guides";

const breadcrumbJurisdictionHref = `/${fmJurisdiction}/`;

const breadcrumbCategoryLabel = categoryEntry?.label || entry.data.category;

const breadcrumbCategoryHref = categoryEntry
  ? `/${fmJurisdiction}/category/${categoryEntry.key}/`
  : `/${fmJurisdiction}/`;

/*
  Central switch for whether this guide is allowed to show ads.

  This keeps the decision in one place and makes sensitive-category
  exclusions straightforward.
*/
const adsAllowed =
  entry.data.category !== "Sexual violence & highly sensitive situations";

const structuredData = buildGuideStructuredData({
  title: entry.data.title,
  category: entry.data.category,
  tags: entry.data.tags || [],
  lastReviewed: entry.data.last_reviewed,
  jurisdiction: fmJurisdiction,
  pathname: Astro.url.pathname,
});
---

<SiteLayout
  title={`${entry.data.title} — PanicStation.org`}
  jurisdiction={urlJurisdiction}
  structuredData={structuredData}
>
  <div
    class="ps-guide"
    id="ps-guide"
    data-ps-url-jurisdiction={urlJurisdiction}
    data-ps-fm-jurisdiction={fmJurisdiction}
    data-pagefind-body
  >
    <span data-pagefind-filter={`jurisdiction:${urlJurisdiction}`} class="ps-search-hidden">
      {urlJurisdiction}
    </span>

    <span data-pagefind-filter={`category:${entry.data.category}`} class="ps-search-hidden">
      {entry.data.category}
    </span>

    <span data-pagefind-weight="2" class="ps-search-hidden">
      {(entry.data.tags || []).join(" • ")}
    </span>

    <Content />

    <section class="ps-card ps-about-guide" data-pagefind-ignore>
      <h2>About this guide</h2>

      <p>
        PanicStation.org guides are written as plain-English first steps, then
        reviewed for clarity, jurisdiction, and source quality. If you notice an
        error, outdated information, unclear wording, or a broken link, please
        contact us.
      </p>

      <nav class="ps-about-guide-actions" aria-label="About this guide links">
        <a class="ps-about-guide-action" href="/contact">Report a correction</a>
        <a class="ps-about-guide-action" href="/editorial">Read Editorial Policy</a>
      </nav>
    </section>

    <template id="ps-guide-breadcrumb-template">
      <nav class="ps-guide-breadcrumb" aria-label="Breadcrumb" data-pagefind-ignore>
        <ol>
          <li>
            <a href={breadcrumbJurisdictionHref}>{breadcrumbJurisdictionLabel}</a>
          </li>
          <li>
            <a href={breadcrumbCategoryHref}>{breadcrumbCategoryLabel}</a>
          </li>
        </ol>
      </nav>
    </template>

    <template id="ps-guide-meta-template">
      <p class="ps-guide-meta" data-pagefind-ignore>
        <span>By PanicStation.org</span>
        <span aria-hidden="true"> · </span>
        <span>Reviewed under our </span><a href="/editorial">editorial policy</a>
        <span aria-hidden="true"> · </span>
        <span>
          Last reviewed:
          <time datetime={entry.data.last_reviewed}>{lastReviewedDisplay}</time>
        </span>
        <span aria-hidden="true"> · </span>
        <span>{guideLabel}</span>
      </p>
    </template>

    <script is:inline>
      (() => {
        const guide = document.getElementById("ps-guide");
        const h1 = guide?.querySelector("h1");
        const breadcrumbTemplate = document.getElementById("ps-guide-breadcrumb-template");
        const metaTemplate = document.getElementById("ps-guide-meta-template");

        if (!guide || !h1 || !breadcrumbTemplate || !metaTemplate) return;
        if (guide.querySelector(".ps-guide-hero")) return;

        const breadcrumb = breadcrumbTemplate.content.firstElementChild.cloneNode(true);
        const meta = metaTemplate.content.firstElementChild.cloneNode(true);

        const hero = document.createElement("div");
        hero.className = "ps-guide-hero";

        h1.insertAdjacentElement("beforebegin", hero);
        hero.appendChild(breadcrumb);
        hero.appendChild(h1);
        hero.appendChild(meta);

        breadcrumbTemplate.remove();
        metaTemplate.remove();
      })();
    </script>

    <div class="ps-guide-actions" aria-label="Guide actions">
      <a
        class="ps-action-btn ps-action-support"
        href="https://www.buymeacoffee.com/panicstation"
        target="_blank"
        rel="noopener noreferrer"
      >
        <i class="fa-solid fa-heart" aria-hidden="true"></i>
        <span>Support us</span>
      </a>

      <button type="button" class="ps-action-btn ps-action-share" id="ps-share-btn">
        <i class="fa-solid fa-share-nodes" aria-hidden="true"></i>
        <span>Share guide</span>
      </button>
    </div>

    <script is:inline define:vars={{ enableAdsenseTest, adsAllowed }}>
      (() => {
        const ADSENSE_CLIENT = "ca-pub-6393180948620179";
        const MID_AD_SLOT_ID = "6400555379";
        const LOWER_AD_SLOT_ID = "6321828040";

        /*
          PRE-APPROVAL / POST-APPROVAL SWITCH

          LOCAL TEST MODE is controlled separately by:
          PUBLIC_ENABLE_ADSENSE_TEST=1

          Leave this true until PanicStation.org is approved in AdSense
          if you also want production pages to keep using AdSense test ads.

          Once the site is approved and you want production to request
          real ads, change this to false.

          This is intentionally separate from PUBLIC_ENABLE_ADSENSE_TEST
          so local/dev behaviour stays explicit and safe to leave committed.
        */
        const PRODUCTION_USES_TEST_ADS = false;

        const shareBtn = document.getElementById("ps-share-btn");
        if (shareBtn) {
          shareBtn.addEventListener("click", async () => {
            const url = window.location.href;
            const title = document.title || "PanicStation.org";
            const text = "PanicStation.org guide";

            if (navigator.share) {
              try {
                await navigator.share({ title, text, url });
                return;
              } catch {
              }
            }

            try {
              await navigator.clipboard.writeText(url);
              shareBtn.classList.add("ps-copied");
              shareBtn.querySelector("span")?.replaceChildren(document.createTextNode("Link copied"));
              setTimeout(() => {
                shareBtn.classList.remove("ps-copied");
                shareBtn.querySelector("span")?.replaceChildren(document.createTextNode("Share guide"));
              }, 1400);
            } catch {
              window.prompt("Copy this link:", url);
            }
          });
        }

        function createAdSlotAfterSection(sectionTitle, id, slotName) {
          let slot = document.getElementById(id);
          if (slot) return slot;

          const section = document.querySelector(`section[data-ps-section="${sectionTitle}"]`);
          if (!section) return null;

          slot = document.createElement("div");
          slot.id = id;
          slot.className = "ps-ad-slot ps-ad-slot-mid";
          slot.hidden = true;
          slot.setAttribute("aria-hidden", "false");
          slot.setAttribute("data-ps-ad-slot", slotName);

          section.insertAdjacentElement("afterend", slot);
          return slot;
        }

        function buildAdSlots() {
          if (!adsAllowed) {
            return {
              mid: null,
              lower: null,
            };
          }

          return {
            mid: createAdSlotAfterSection("Short answer", "ps-mid-ad", "mid"),
            lower: createAdSlotAfterSection("Scope note", "ps-lower-ad", "lower"),
          };
        }

        const adSlots = buildAdSlots();

        const adStates = {
          mid: { started: false, finished: false },
          lower: { started: false, finished: false },
        };

        function getAdQueue() {
          window.adsbygoogle = window.adsbygoogle || [];
          return window.adsbygoogle;
        }

        function getAdSlot(key) {
          return adSlots[key] || null;
        }

        function hasAdSlot(key) {
          return !!getAdSlot(key);
        }

        function collapseAd(key) {
          const slot = getAdSlot(key);
          if (!slot) return;

          slot.hidden = true;
          slot.setAttribute("aria-hidden", "true");
          slot.innerHTML = "";

          delete slot.dataset.psAdLoaded;
          delete slot.dataset.psAdMode;
          delete slot.dataset.psAdStatus;
        }

        function openAdFrameAndInsertMarkup(key, slotId, { testMode = false, requestMode = "personalized" } = {}) {
          const slot = getAdSlot(key);
          if (!slot) return null;

          const adtestAttr = testMode ? `data-adtest="on"` : "";

          slot.innerHTML = `
            <div class="ps-ad-shell">
              <div class="ps-ad-label" aria-hidden="true">Advertisement</div>
              <ins
                class="adsbygoogle"
                style="display:block; text-align:center;"
                data-ad-layout="in-article"
                data-ad-format="fluid"
                data-ad-client="${ADSENSE_CLIENT}"
                data-ad-slot="${slotId}"
                ${adtestAttr}
              ></ins>
            </div>
          `;

          slot.hidden = false;
          slot.setAttribute("aria-hidden", "false");
          slot.dataset.psAdMode = requestMode;

          return slot.querySelector("ins.adsbygoogle");
        }

        window.PanicStationAds = {
          collapseMidAd() {
            collapseAd("mid");
          },
          hasMidAdSlot() {
            return hasAdSlot("mid");
          },
          collapseLowerAd() {
            collapseAd("lower");
          },
          hasLowerAdSlot() {
            return hasAdSlot("lower");
          },
        };

        async function loadAdsenseScriptOnce({ pauseRequests = false } = {}) {
          const queue = getAdQueue();

          if (pauseRequests) {
            queue.pauseAdRequests = 1;
          }

          const selector = `script[src*="adsbygoogle.js?client=${ADSENSE_CLIENT}"]`;
          const existing = document.querySelector(selector);

          if (existing) {
            if (window.adsbygoogle) return true;

            try {
              await new Promise((resolve, reject) => {
                existing.addEventListener("load", resolve, { once: true });
                existing.addEventListener("error", () => reject(new Error("AdSense script failed")), { once: true });
              });
            } catch {
              return false;
            }

            return !!window.adsbygoogle;
          }

          const script = document.createElement("script");
          script.async = true;
          script.src = `https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}`;
          script.crossOrigin = "anonymous";

          const loaded = new Promise((resolve, reject) => {
            script.addEventListener("load", resolve, { once: true });
            script.addEventListener("error", () => reject(new Error("AdSense script failed")), { once: true });
          });

          document.head.appendChild(script);

          try {
            await loaded;
            return !!window.adsbygoogle;
          } catch {
            return false;
          }
        }

        function markSlotStatusFromIns(key, ins) {
          const slot = getAdSlot(key);
          if (!slot || !ins) return;

          const status = ins.getAttribute("data-ad-status");
          if (status) slot.dataset.psAdStatus = status;
        }

        function applyAdRequestMode(requestMode) {
          const queue = getAdQueue();

          if (requestMode === "non-personalized") {
            queue.requestNonPersonalizedAds = 1;
          } else {
            queue.requestNonPersonalizedAds = 0;
          }

          queue.pauseAdRequests = 0;
        }

        async function tryRenderAd(key, slotId, { testMode = false, requestMode = "personalized" } = {}) {
          const slot = getAdSlot(key);
          const state = adStates[key];

          if (!slot || !state) return;
          if (state.started || state.finished) return;

          state.started = true;

          const scriptReady = await loadAdsenseScriptOnce();
          if (!scriptReady) {
            state.started = false;
            collapseAd(key);
            return;
          }

          const ins = openAdFrameAndInsertMarkup(key, slotId, { testMode, requestMode });
          if (!ins) {
            state.started = false;
            collapseAd(key);
            return;
          }

          try {
            getAdQueue().push({});
          } catch {
            state.started = false;
            collapseAd(key);
            return;
          }

          const startedAt = Date.now();
          const timeoutMs = 5000;
          const intervalMs = 250;

          const timer = window.setInterval(() => {
            if (!document.body.contains(ins)) {
              window.clearInterval(timer);
              state.started = false;
              collapseAd(key);
              return;
            }

            markSlotStatusFromIns(key, ins);

            const status = ins.getAttribute("data-ad-status");

            if (status === "filled") {
              window.clearInterval(timer);
              state.finished = true;
              slot.hidden = false;
              slot.setAttribute("aria-hidden", "false");
              slot.dataset.psAdLoaded = "1";
              return;
            }

            if (status === "unfilled") {
              window.clearInterval(timer);
              state.started = false;
              collapseAd(key);
              return;
            }

            if (Date.now() - startedAt >= timeoutMs) {
              window.clearInterval(timer);

              const initialized =
                ins.classList.contains("adsbygoogle-noablate") ||
                ins.hasAttribute("data-adsbygoogle-status") ||
                !!ins.getAttribute("data-ad-status") ||
                ins.childElementCount > 0;

              if (initialized) {
                state.finished = true;
                slot.hidden = false;
                slot.setAttribute("aria-hidden", "false");
                slot.dataset.psAdLoaded = "1";
              } else {
                state.started = false;
                collapseAd(key);
              }
            }
          }, intervalMs);
        }

        function startLocalTestAds() {
          if (!adsAllowed) return;

          if (hasAdSlot("mid")) {
            tryRenderAd("mid", MID_AD_SLOT_ID, { testMode: true, requestMode: "personalized" });
          }

          if (hasAdSlot("lower")) {
            tryRenderAd("lower", LOWER_AD_SLOT_ID, { testMode: true, requestMode: "personalized" });
          }
        }

        function createBlockedDecision(reason) {
          return {
            allowAds: false,
            requestMode: "blocked",
            reason,
          };
        }

        function deriveDecisionFromConsentModeValues(values) {
          const statusEnum = window.googlefc?.ConsentModePurposeStatusEnum;
          if (!values || !statusEnum) {
            return createBlockedDecision("missing-consent-mode-values");
          }

          const {
            UNKNOWN,
            GRANTED,
            DENIED,
            NOT_APPLICABLE,
          } = statusEnum;

          const adStorage = values.adStoragePurposeConsentStatus;
          const adUserData = values.adUserDataPurposeConsentStatus;
          const adPersonalization = values.adPersonalizationPurposeConsentStatus;

          const isGrantedOrNotApplicable = (value) =>
            value === GRANTED || value === NOT_APPLICABLE;

          if (
            isGrantedOrNotApplicable(adStorage) &&
            isGrantedOrNotApplicable(adUserData) &&
            isGrantedOrNotApplicable(adPersonalization)
          ) {
            return {
              allowAds: true,
              requestMode: "personalized",
              reason: "consent-or-not-applicable",
            };
          }

          /*
            Conservative non-personalised path:

            - ad_storage must still be available
            - if personalisation and/or ad user data are denied, request NPA
            - if ad_storage itself is denied or unknown, do not request ads
          */
          if (
            isGrantedOrNotApplicable(adStorage) &&
            (adUserData === DENIED || adPersonalization === DENIED)
          ) {
            return {
              allowAds: true,
              requestMode: "non-personalized",
              reason: "non-personalized-only",
            };
          }

          if (adStorage === UNKNOWN || adUserData === UNKNOWN || adPersonalization === UNKNOWN) {
            return createBlockedDecision("consent-still-unknown");
          }

          return createBlockedDecision("ads-not-permitted");
        }

        function waitForGoogleConsentDecision() {
          return new Promise((resolve) => {
            let settled = false;

            const settle = (decision) => {
              if (settled) return;
              settled = true;
              resolve(decision);
            };

            /*
              Privacy & messaging uses the googlefc API. We only act once
              CONSENT_MODE_DATA_READY fires, which means Google’s consent-mode
              values are available for this user.

              If that never arrives, fail closed in production.
            */
            window.googlefc = window.googlefc || {};
            window.googlefc.usstatesoptout = window.googlefc.usstatesoptout || {};
            window.googlefc.callbackQueue = window.googlefc.callbackQueue || [];

            const timeoutMs = 8000;
            const timeoutId = window.setTimeout(() => {
              settle(createBlockedDecision("googlefc-timeout"));
            }, timeoutMs);

            window.googlefc.callbackQueue.push({
              CONSENT_MODE_DATA_READY: () => {
                window.clearTimeout(timeoutId);

                try {
                  const values = window.googlefc.getGoogleConsentModeValues?.();
                  settle(deriveDecisionFromConsentModeValues(values));
                } catch {
                  settle(createBlockedDecision("googlefc-read-failed"));
                }
              },
            });
          });
        }

        async function startProductionAdsWithGoogleConsent() {
          if (!adsAllowed) return;

          /*
            Important order:

            1) Load AdSense script in paused mode so Google Privacy & messaging
               can run without any ad requests being sent yet.
            2) Wait for Google consent data to become available.
            3) Decide whether to request personalised ads, NPA, or no ads.
            4) Only then open the visible ad frame and push each ad request.
          */
          const scriptReady = await loadAdsenseScriptOnce({ pauseRequests: true });
          if (!scriptReady) {
            collapseAd("mid");
            collapseAd("lower");
            return;
          }

          const decision = await waitForGoogleConsentDecision();

          if (!decision.allowAds) {
            collapseAd("mid");
            collapseAd("lower");
            return;
          }

          applyAdRequestMode(decision.requestMode);

          const useTestAds = PRODUCTION_USES_TEST_ADS;

          if (hasAdSlot("mid")) {
            tryRenderAd("mid", MID_AD_SLOT_ID, {
              testMode: useTestAds,
              requestMode: decision.requestMode,
            });
          }

          if (hasAdSlot("lower")) {
            tryRenderAd("lower", LOWER_AD_SLOT_ID, {
              testMode: useTestAds,
              requestMode: decision.requestMode,
            });
          }
        }

        if (!adsAllowed) {
          collapseAd("mid");
          collapseAd("lower");
          return;
        }

        window.setTimeout(() => {
          if (enableAdsenseTest) {
            startLocalTestAds();
            return;
          }

          startProductionAdsWithGoogleConsent();
        }, 300);
      })();
    </script>
  </div>
</SiteLayout>