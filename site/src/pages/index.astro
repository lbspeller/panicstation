---
const title = "PanicStation.org";
const description = "Calm, practical first-step guidance for sudden, panic-inducing situations.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="header">
      <div class="brand">PanicStation<span class="dot">.org</span></div>
      <div class="toggle" aria-label="Jurisdiction">
        <button class="pill" type="button">UK</button>
        <button class="pill active" type="button">USA</button>
      </div>
    </header>

    <main class="main">
      <div class="searchWrap">
        <label class="srOnly" for="q">Search for a guide</label>
        <input id="q" class="search" type="search" placeholder="Search for a guide…" />
        <button class="searchBtn" type="button" aria-label="Search">🔍</button>
      </div>

      <footer class="footer">
        <a href="/about">About</a>
        <a href="/disclaimer">Disclaimer</a>
        <a href="/privacy">Privacy</a>
        <span class="copy">© {new Date().getFullYear()} PanicStation.org</span>
      </footer>
    </main>

    <style>
      :global(body) {
        margin: 0;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        color: #0b1220;
        background: #f6f7fb;
      }
      .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 20px;
        max-width: 1100px;
        margin: 0 auto;
      }
      .brand {
        font-weight: 800;
        font-size: 34px;
        letter-spacing: -0.5px;
      }
      .dot { color: #d24b4b; font-weight: 800; }
      .toggle {
        display: flex;
        gap: 10px;
        background: #eef1f7;
        padding: 6px;
        border-radius: 999px;
        border: 1px solid #dde3ef;
      }
      .pill {
        border: 0;
        background: transparent;
        padding: 10px 14px;
        border-radius: 999px;
        cursor: pointer;
        font-weight: 600;
      }
      .pill.active {
        background: #224b7a;
        color: white;
      }
      .main {
        min-height: calc(100vh - 72px);
        display: grid;
        place-items: center;
        padding: 20px;
      }
      .searchWrap {
        width: min(860px, 100%);
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 10px;
        align-items: center;
      }
      .search {
        width: 100%;
        font-size: 18px;
        padding: 16px 18px;
        border-radius: 999px;
        border: 1px solid #d9dfec;
        outline: none;
        background: white;
      }
      .search:focus {
        border-color: #224b7a;
        box-shadow: 0 0 0 3px rgba(34, 75, 122, 0.15);
      }
      .searchBtn {
        border: 0;
        background: #224b7a;
        color: white;
        padding: 14px 18px;
        border-radius: 999px;
        cursor: pointer;
        font-size: 18px;
      }
      .footer {
        margin-top: 18px;
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        justify-content: center;
        font-size: 14px;
        color: #4b5568;
      }
      .footer a { color: inherit; text-decoration: none; }
      .footer a:hover { text-decoration: underline; }
      .copy { opacity: 0.9; }
      .srOnly {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      /* Responsive tweaks */
      @media (max-width: 520px) {
        .brand { font-size: 28px; }
        .searchWrap { grid-template-columns: 1fr; }
        .searchBtn { width: 100%; }
      }
    </style>
  </body>
</html>