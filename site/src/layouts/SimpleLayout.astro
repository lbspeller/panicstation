---
const { title } = Astro.props;
const path = Astro.url.pathname;
const isGuidesIndex = path === "/guides/";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Font Awesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
      referrerpolicy="no-referrer"
    />

    <!-- Google AdSense (publisher ID) -->
    <meta name="google-adsense-account" content="ca-pub-6393180948620179" />
  </head>

  <body class={`ps-page ${isGuidesIndex ? "ps-guides-index" : ""}`} data-ps-page="other">
    <header class="ps-header ps-header-simple">
      <div class="ps-header-inner">
        <a class="ps-brand" href="/" aria-label="PanicStation.org home">
          <span class="ps-brand-main">PanicStation</span><span class="ps-brand-dot">.org</span>
        </a>
      </div>
    </header>

    <main class="ps-shell">
      <slot />
    </main>

    <footer class="ps-footer">
      <div class="ps-footer-inner">
        <span>© {new Date().getFullYear()} PanicStation.org</span>
        <span class="ps-footer-links">
          {isGuidesIndex ? (
            <span class="ps-footer-link" aria-hidden="true"></span>
          ) : (
            <a class="ps-footer-link" href="/guides/">All guides</a>
          )}
        </span>
      </div>
    </footer>
  </body>
</html>

<style>
  :global(*),
  :global(*::before),
  :global(*::after){
    box-sizing: border-box;
  }

  :global(html){
    scrollbar-gutter: stable;
  }

  :global(body){
    margin:0;
    background:#f6f7fb;
    color:#0b1220;
    font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  }

  :global(:root){
    --ps-accent: #224b7a;
    --ps-border: #d9dfec;
    --ps-soft: #eef1f7;
    --ps-logo-red: #d24b4b;
  }

  .ps-page{
    min-height: 100vh;   /* fallback */
    display: flex;
    flex-direction: column;
  }

  /* Prefer the visible viewport on mobile browsers */
  @supports (min-height: 100svh){
    .ps-page{ min-height: 100svh; }
  }
  @supports (min-height: 100dvh){
    .ps-page{ min-height: 100dvh; }
  }

  .ps-shell{
    flex: 1;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0px 16px 0;
    min-height: 0;
  }

  /* Guides index (and other short pages, if you reuse this class) */
  .ps-guides-index .ps-shell{
    flex: 0;
  }

  .ps-header{
    padding: 22px 0 18px;
    background: linear-gradient(#f7f8fc, #f6f7fb);
  }

  .ps-header-inner{
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 16px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;

    /* match SiteLayout: keep header row single-line */
    flex-wrap: nowrap;
  }

  /* match SiteLayout: allow shrinking without clipping on narrow screens */
  .ps-brand{
    flex: 1 1 auto;
    min-width: 0;

    text-decoration:none;
    font-weight: 900;
    font-size: clamp(20px, 5.8vw, 44px);
    letter-spacing:-0.6px;
    color:#0b1220;
    white-space: nowrap;
  }
  .ps-brand-dot{ color: var(--ps-logo-red); }

  .ps-footer{
    margin: 0;
    padding: 18px 16px 32px;
    color:#4b5568;
    font-size:14px;
    margin-top: auto; /* stick footer to bottom when content is short */
    padding-bottom: calc(32px + env(safe-area-inset-bottom, 0px));
  }

  .ps-footer-inner{
    max-width: 1100px;
    margin:0 auto;
    display:flex;
    flex-wrap:wrap;
    gap:12px;
    justify-content:space-between;
  }

  /* match SiteLayout: allow wrapping so links never disappear below fold */
  .ps-footer-links{
    display:flex;
    align-items:center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .ps-footer-link{
    color: inherit;
    font: inherit;
    text-decoration: none;
  }

  a.ps-footer-link:hover{ text-decoration: underline; }

  /* ultra-narrow phones */
  @media (max-width: 360px){
    .ps-brand{ font-size: clamp(18px, 5.2vw, 40px); }
  }
</style>