---
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>

  <body class="ps-page">
    <header class="ps-header">
      <div class="ps-header-inner">
        <a class="ps-brand" href="/" aria-label="PanicStation.org home">
          <span class="ps-brand-main">PanicStation</span><span class="ps-brand-dot">.org</span>
        </a>
      </div>
    </header>

    <main class="ps-shell">
      <nav class="ps-page-actions ps-page-actions-top" aria-label="Page actions">
        <button class="ps-page-action ps-back-button" type="button">Back</button>
        <a class="ps-page-action" href="/">Home</a>
      </nav>

      <slot />

      <nav class="ps-page-actions ps-page-actions-bottom" aria-label="Page actions">
        <button class="ps-page-action ps-back-button" type="button">Back</button>
        <a class="ps-page-action" href="/">Home</a>
      </nav>
    </main>

    <script is:inline>
      (() => {
        const backButtons = document.querySelectorAll(".ps-back-button");
        if (!backButtons.length) return;

        backButtons.forEach((backButton) => {
          backButton.addEventListener("click", () => {
            if (window.history.length > 1) {
              window.history.back();
              return;
            }

            window.location.href = "/";
          });
        });
      })();
    </script>
  </body>
</html>

<style>
  :global(*),
  :global(*::before),
  :global(*::after){
    box-sizing: border-box;
  }

  :global(html){
    scrollbar-gutter: stable;
  }

  :global(body){
    margin: 0;
    background: #f6f7fb;
    color: #0b1220;
    font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  }

  :global(:root){
    --ps-accent: #224b7a;
    --ps-border: #d9dfec;
    --ps-soft: #eef1f7;
    --ps-logo-red: #d24b4b;
    --ps-muted: #546070;
    --ps-shadow: 0 1px 0 rgba(0,0,0,.02), 0 8px 24px rgba(15, 23, 42, 0.04);
  }

  .ps-page{
    min-height: 100vh;
  }

  @supports (min-height: 100svh){
    .ps-page{
      min-height: 100svh;
    }
  }

  @supports (min-height: 100dvh){
    .ps-page{
      min-height: 100dvh;
    }
  }

  .ps-header{
    padding: 22px 0 18px;
    background: linear-gradient(#f7f8fc, #f6f7fb);
  }

  .ps-header-inner{
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 16px;
    display: flex;
    align-items: center;
  }

  .ps-brand{
    flex: 1 1 auto;
    min-width: 0;
    text-decoration: none;
    font-weight: 900;
    font-size: clamp(20px, 5.8vw, 44px);
    letter-spacing: -0.6px;
    color: #0b1220;
    white-space: nowrap;
  }

  .ps-brand-dot{
    color: var(--ps-logo-red);
  }

  .ps-shell{
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 16px 56px;
  }

  :global(.ps-page-text){
    background: #fff;
    border: 1px solid #dbe2ef;
    border-radius: 18px;
    padding: clamp(20px, 3vw, 30px);
    line-height: 1.7;
    box-shadow: var(--ps-shadow);
  }

  :global(.ps-page-text h1){
    margin: 0 0 20px;
    font-size: clamp(24px, 3vw, 36px);
    line-height: 1.15;
    letter-spacing: -0.4px;
    font-weight: 900;
  }

  :global(.ps-page-text h2){
    margin: 32px 0 12px;
    padding-top: 18px;
    border-top: 1px solid #eef1f7;
    font-size: clamp(18px, 2.1vw, 22px);
    line-height: 1.25;
    letter-spacing: -0.2px;
    font-weight: 900;
    color: #0b1220;
  }

  :global(.ps-page-text h1 + h2){
    margin-top: 24px;
  }

  :global(.ps-page-text p){
    margin: 12px 0;
    font-size: 16px;
  }

  :global(.ps-page-text ul){
    margin: 12px 0 18px 22px;
    padding: 0;
  }

  :global(.ps-page-text li){
    margin: 8px 0;
    padding-left: 2px;
  }

  :global(.ps-page-text strong){
    font-weight: 850;
  }

  :global(.ps-page-text a){
    color: var(--ps-accent);
    font-weight: 700;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  :global(.ps-page-text a:hover){
    text-decoration-thickness: 2px;
  }

  .ps-page-actions{
    display: flex;
    justify-content: flex-end;
    gap: 12px;
  }

  .ps-page-actions-top{
    margin: 0 0 18px;
  }

  .ps-page-actions-bottom{
    margin: 18px 0 0;
  }

  .ps-page-action{
    border: 1px solid var(--ps-border);
    background: #fff;
    color: #0b1220;
    border-radius: 999px;
    padding: 10px 14px;
    font: inherit;
    font-weight: 800;
    text-decoration: none;
    cursor: pointer;
    box-shadow: 0 1px 0 rgba(0,0,0,.02);
  }

  .ps-page-action:hover{
    background: rgba(34, 75, 122, 0.06);
    text-decoration: none;
  }

  .ps-page-action:focus{
    outline: none;
  }

  .ps-page-action:focus-visible{
    box-shadow: 0 0 0 3px rgba(34, 75, 122, 0.18);
  }

  @media (max-width: 520px){
    :global(.ps-page-text){
      border-radius: 16px;
      padding: 18px 16px;
    }

    :global(.ps-page-text h2){
      margin-top: 28px;
      padding-top: 16px;
    }

    .ps-page-actions{
      flex-wrap: wrap;
    }
  }

  @media (max-width: 360px){
    .ps-brand{
      font-size: clamp(18px, 5.2vw, 40px);
    }
  }
</style>