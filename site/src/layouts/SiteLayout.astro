---
 // src/layouts/SiteLayout.astro
import UkFlagUrl from "../assets/flags/uk.svg?url";
import UsFlagUrl from "../assets/flags/us.svg?url";
import StructuredData from "../components/StructuredData.astro";

const {
  title,
  jurisdiction,
  structuredData = [],
  description = "Calm, practical first-step guidance for sudden, stressful situations.",
  robots,
  socialTitle = title,
} = Astro.props;

const path = Astro.url.pathname;
const isGuide = /^\/(uk|us)\//i.test(path);
const isHome = path === "/";

const guideSlug = isGuide ? path.replace(/^\/(uk|us)\//i, "") : "";
const ukGuideHref = isGuide ? `/uk/${guideSlug}` : null;
const usGuideHref = isGuide ? `/us/${guideSlug}` : null;

const isUkActive = jurisdiction === "uk";
const isUsActive = jurisdiction === "us";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}

    <meta property="og:site_name" content="PanicStation.org" />
    <meta property="og:type" content={isGuide ? "article" : "website"} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={description} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={description} />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Font Awesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
      referrerpolicy="no-referrer"
    />

    <!-- Google AdSense -->
    <meta name="google-adsense-account" content="ca-pub-6393180948620179" />

    <StructuredData data={structuredData} />

    {isHome && (
      <script is:inline>
        (() => {
          const ADSENSE_CLIENT = "ca-pub-6393180948620179";

          window.adsbygoogle = window.adsbygoogle || [];
          window.adsbygoogle.pauseAdRequests = 1;

          const existing = document.querySelector(
            `script[src*="adsbygoogle.js?client=${ADSENSE_CLIENT}"]`
          );
          if (existing) return;

          const s = document.createElement("script");
          s.async = true;
          s.src = `https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}`;
          s.crossOrigin = "anonymous";
          document.head.appendChild(s);
        })();
      </script>
    )}
  </head>

  <body class={`ps-page ${isHome ? "ps-home" : ""}`} data-ps-page={isHome ? "home" : isGuide ? "guide" : "other"}>
    <header class="ps-header">
      <div class="ps-header-inner">
        <a class="ps-brand" href="/" id="ps-home-link" aria-label="PanicStation.org home">
          <span class="ps-brand-main">PanicStation</span><span class="ps-brand-dot">.org</span>
        </a>

        <div class="ps-toggle" role="group" aria-label="Jurisdiction toggle">
          <a
            class={`ps-pill ${isUkActive ? "active" : ""}`}
            href={!isUkActive && isGuide ? ukGuideHref : undefined}
            data-ps-jurisdiction="uk"
            aria-current={isUkActive ? "page" : undefined}
            aria-disabled={isUkActive ? "true" : undefined}
            tabindex={isUkActive ? -1 : undefined}
          >
            <img class="ps-flag" src={UkFlagUrl} alt="" aria-hidden="true" />
            UK
          </a>

          <a
            class={`ps-pill ${isUsActive ? "active" : ""}`}
            href={!isUsActive && isGuide ? usGuideHref : undefined}
            data-ps-jurisdiction="us"
            aria-current={isUsActive ? "page" : undefined}
            aria-disabled={isUsActive ? "true" : undefined}
            tabindex={isUsActive ? -1 : undefined}
          >
            <img class="ps-flag" src={UsFlagUrl} alt="" aria-hidden="true" />
            USA
          </a>
        </div>
      </div>

      <div class="ps-searchbar">
        <div class="ps-searchbar-inner">
          {isHome && (
            <div class="ps-home-search-intro">
              <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
              <p class="ps-home-search-title">
                <strong>What to do if...</strong> Something stressful happened.<br />
                Search for the situation and find a clear first step.
              </p>
            </div>
          )}

          <div class="ps-search-wrap">
            <input
              id="ps-search"
              class="ps-search"
              type="search"
              placeholder="What happened?"
              autocomplete="off"
            />

            <div class="ps-search-icons" aria-label="Search controls">
              <button id="ps-clear-btn" class="ps-icon-btn ps-clear-btn" type="button" aria-label="Clear search" hidden>
                <i class="fa-solid fa-xmark" aria-hidden="true"></i>
              </button>

              <button id="ps-filter-btn" class="ps-icon-btn" type="button" aria-label="Filter by category">
                <span class="ps-filter-icon-wrap">
                  <i class="fa-solid fa-filter" aria-hidden="true"></i>
                  <span id="ps-filter-badge" class="ps-filter-badge" hidden></span>
                </span>
              </button>

              <button id="ps-search-btn" class="ps-icon-btn" type="button" aria-label="Search">
                <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
              </button>
            </div>
          </div>

          <div id="ps-search-hint" class="ps-search-hint" hidden>
            <i class="fa-solid fa-lightbulb" aria-hidden="true"></i>
            <span>Start typing to search for a guide. Use the filter button to narrow results by category</span>
          </div>
        </div>

        <div id="ps-search-results" class="ps-search-results" hidden>
          <div class="ps-search-results-inner" role="listbox" aria-label="Search results"></div>
        </div>

        <div id="ps-filter-box" class="ps-filter-box" hidden>
          <div class="ps-filter-box-inner" role="group" aria-label="Category filters"></div>
        </div>
      </div>
    </header>

    <main class="ps-shell">
      <section id="ps-home-results" class="ps-home-results" hidden>
        <div class="ps-home-results-inner">
          <div class="ps-home-results-head">
            <div id="ps-home-results-title" class="ps-home-results-title"></div>
            <button
              id="ps-home-results-clear"
              class="ps-home-results-clear"
              type="button"
              aria-label="Reset search results"
              title="Reset search results"
              hidden
            >
              <i class="fa-solid fa-xmark" aria-hidden="true"></i>
            </button>
          </div>
          <div id="ps-home-results-list" class="ps-home-results-list" role="list"></div>
        </div>
      </section>

      <slot />
    </main>

    <footer class="ps-footer">
      <div class="ps-footer-inner">
        <nav class="ps-footer-links" aria-label="Footer links">
          <a class="ps-footer-link" href="/about">About</a>
          <a class="ps-footer-link" href="/contact">Contact</a>
          <a class="ps-footer-link" href="/disclaimer">Disclaimer</a>
          <a class="ps-footer-link" href="/editorial">Editorial Policy</a>
          <a class="ps-footer-link" href="/privacy">Privacy</a>
          <a class="ps-footer-link" href="/guides/">All guides</a>
        </nav>

        <div class="ps-footer-copyright">
          © {new Date().getFullYear()} PanicStation.org
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const pageType = document.body.getAttribute("data-ps-page");
        const toggle = document.querySelector(".ps-toggle");
        if (!toggle) return;

        const setActive = (jur) => {
          toggle.querySelectorAll(".ps-pill").forEach((el) => {
            const isActive = el.getAttribute("data-ps-jurisdiction") === jur;
            el.classList.toggle("active", isActive);
            if (isActive) {
              el.setAttribute("aria-disabled", "true");
              el.setAttribute("tabindex", "-1");
              el.removeAttribute("href");
            } else {
              el.removeAttribute("aria-disabled");
              el.removeAttribute("tabindex");
            }
          });
        };

        toggle.addEventListener("click", async (e) => {
          const a = e.target.closest("a.ps-pill");
          if (!a) return;
          if (a.getAttribute("aria-disabled") === "true") return;

          const targetJur = a.getAttribute("data-ps-jurisdiction");
          if (!targetJur) return;

          if (pageType === "home") {
            e.preventDefault();
            localStorage.setItem("ps_jurisdiction", targetJur);
            setActive(targetJur);
            window.dispatchEvent(new CustomEvent("ps:jurisdiction", { detail: targetJur }));
            return;
          }

          if (pageType === "guide") {
            const href = a.getAttribute("href");
            if (!href) {
              localStorage.setItem("ps_jurisdiction", targetJur);
              location.href = "/";
              return;
            }

            e.preventDefault();
            localStorage.setItem("ps_jurisdiction", targetJur);

            try {
              let ok = false;
              try {
                const r = await fetch(href, { method: "HEAD" });
                ok = r.ok;
              } catch {
                const r = await fetch(href, { method: "GET" });
                ok = r.ok;
              }
              location.href = ok ? href : "/";
            } catch {
              location.href = "/";
            }
          }
        });

        if (pageType === "home") {
          const saved = localStorage.getItem("ps_jurisdiction");
          if (saved === "uk" || saved === "us") setActive(saved);
        }
      })();
    </script>

    <script is:inline>
      (() => {
        const homeLink = document.getElementById("ps-home-link");
        if (!homeLink) return;

        homeLink.addEventListener("click", () => {
          localStorage.removeItem("ps_categories");
          sessionStorage.removeItem("ps_show_results");
          sessionStorage.removeItem("ps_results_query");
        });
      })();
    </script>

    <script type="module">
      const input = document.getElementById("ps-search");
      const clearBtn = document.getElementById("ps-clear-btn");
      const searchBtn = document.getElementById("ps-search-btn");
      const box = document.getElementById("ps-search-results");
      const inner = box?.querySelector(".ps-search-results-inner");

      const filterBtn = document.getElementById("ps-filter-btn");
      const filterBadge = document.getElementById("ps-filter-badge");
      const filterBox = document.getElementById("ps-filter-box");
      const filterInner = filterBox?.querySelector(".ps-filter-box-inner");

      const hint = document.getElementById("ps-search-hint");

      const homePanel = document.getElementById("ps-home-results");
      const homeTitle = document.getElementById("ps-home-results-title");
      const homeList = document.getElementById("ps-home-results-list");
      const homeClear = document.getElementById("ps-home-results-clear");

      const pageType = document.body.getAttribute("data-ps-page");

      if (!input || !searchBtn || !box || !inner || !filterBtn || !filterBox || !filterInner) {
      } else {
        function dismissKeyboard() {
          input.blur();
          window.getSelection?.()?.removeAllRanges?.();
        }

        function updateClearVisibility() {
          if (!clearBtn) return;
          const hasText = (input.value || "").trim().length > 0;
          clearBtn.hidden = !hasText;
        }

        updateClearVisibility();

        clearBtn?.addEventListener("click", () => {
          input.value = "";
          updateClearVisibility();
          hideSearchResults();
          hideFilter();
          hideHomePanel();
          updateHintVisibility();
          input.focus();
        });

        let pf = null;

        async function ensurePagefind() {
          if (pf) return pf;
          pf = await import("/pagefind/pagefind.js");
          return pf;
        }

        const norm = (s) => (s || "").toLowerCase().replace(/\s+/g, " ").trim();
        const escapeHtml = (s) =>
          String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

        const CATEGORIES = [
          { key: "bereavement", label: "Bereavement & Family Crises",        icon: "fa-heart-crack" },
          { key: "legal",       label: "Legal, Police & Official Matters",   icon: "fa-scale-balanced" },
          { key: "sexual",      label: "Sexual Violence & Sensitive Issues", icon: "fa-hand" },
          { key: "travel",      label: "Travel, Documents & Abroad",         icon: "fa-passport" },
          { key: "health",      label: "Health & Medical Scares",            icon: "fa-kit-medical" },
          { key: "money",       label: "Money & Financial Emergencies",      icon: "fa-sterling-sign" },
          { key: "tech",        label: "Tech & Digital Loss",                icon: "fa-lock" },
          { key: "work",        label: "Work & Employment Crises",           icon: "fa-briefcase" },
          { key: "home",        label: "Home & Property Emergencies",        icon: "fa-house-circle-exclamation" },
          { key: "safety",      label: "Personal Safety & Immediate Danger", icon: "fa-shield-halved" },
          { key: "transport",   label: "Transport & Mobility Issues",        icon: "fa-car-burst" },
        ];

        const CATEGORY_FULL = {
          bereavement: "Death, bereavement & serious family crises",
          health: "Health & medical scares",
          home: "Home & property emergencies",
          legal: "Legal, police, prison & official contact",
          money: "Money & financial emergencies",
          safety: "Personal safety & immediate danger",
          sexual: "Sexual violence & highly sensitive situations",
          tech: "Technology & digital loss",
          transport: "Transport & mobility emergencies",
          travel: "Travel, documents & being abroad",
          work: "Work & employment crises",
        };

        const ICON_BY_FULL_CATEGORY = (() => {
          const m = new Map();
          for (const c of CATEGORIES) {
            const full = CATEGORY_FULL[c.key];
            if (full) m.set(full, c.icon);
          }
          return m;
        })();

        let selectedCategoryKeys = [];
        let draftCategoryKeys = [];

        function arraysEqual(a, b) {
          if (a.length !== b.length) return false;
          return a.every((v, i) => v === b[i]);
        }

        function sortCategoryKeys(keys) {
          const order = new Map(CATEGORIES.map((c, i) => [c.key, i]));
          return [...keys].sort((a, b) => (order.get(a) ?? 999) - (order.get(b) ?? 999));
        }

        function updateFilterButtonState() {
          const count = selectedCategoryKeys.length;
          filterBtn.classList.toggle("ps-filter-active", count > 0);

          if (filterBadge) {
            filterBadge.hidden = count === 0;
            filterBadge.textContent = count === 0 ? "" : String(count);
          }
        }

        function updateHintVisibility() {
          if (!hint) return;

          if (pageType !== "home") {
            hint.hidden = true;
            return;
          }

          const hasText = norm(input.value).length > 0;
          const hasCategory = selectedCategoryKeys.length > 0;

          const suggestionsShowing = box && !box.hidden;
          const filtersShowing = filterBox && !filterBox.hidden;
          const resultsShowing = homePanel && !homePanel.hidden;

          const shouldShow =
            !hasCategory &&
            !hasText &&
            !suggestionsShowing &&
            !resultsShowing &&
            !filtersShowing;

          hint.hidden = !shouldShow;
        }

        let activeIndex = -1;

        function getResultButtons() {
          return Array.from(inner.querySelectorAll("button.ps-result-btn"));
        }

        function focusResultAt(i) {
          const btns = getResultButtons();
          if (!btns.length) return;
          if (i < 0) i = 0;
          if (i >= btns.length) i = btns.length - 1;
          activeIndex = i;
          btns[i].focus();
        }

        const hideSearchResults = () => {
          box.hidden = true;
          inner.innerHTML = "";
          activeIndex = -1;
          updateHintVisibility();
        };

        const showSearchResults = () => {
          box.hidden = false;
          updateHintVisibility();
        };

        const hideFilter = () => {
          filterBox.hidden = true;
          filterInner.innerHTML = "";
          updateHintVisibility();
        };

        const showFilter = () => {
          filterBox.hidden = false;
          updateHintVisibility();
        };

        function persistCategorySelection() {
          if (selectedCategoryKeys.length) localStorage.setItem("ps_categories", JSON.stringify(selectedCategoryKeys));
          else localStorage.removeItem("ps_categories");
        }

        function restoreCategorySelection() {
          const raw = localStorage.getItem("ps_categories");
          if (!raw) return;

          try {
            const parsed = JSON.parse(raw);
            if (!Array.isArray(parsed)) return;

            const valid = parsed.filter((key) => CATEGORIES.some((x) => x.key === key));
            selectedCategoryKeys = sortCategoryKeys(valid);
          } catch {
            selectedCategoryKeys = [];
          }

          updateFilterButtonState();
          updateHintVisibility();
        }

        function renderCategoryBox() {
          filterInner.innerHTML = "";
          const frag = document.createDocumentFragment();

          for (const c of CATEGORIES) {
            const b = document.createElement("button");
            b.type = "button";
            b.className = "ps-cat-pill";
            b.setAttribute("role", "checkbox");
            b.setAttribute("aria-checked", draftCategoryKeys.includes(c.key) ? "true" : "false");
            b.dataset.key = c.key;

            if (draftCategoryKeys.includes(c.key)) b.classList.add("ps-selected");

            b.innerHTML = `
              <span class="ps-cat-left" aria-hidden="true">
                <i class="fa-solid ${c.icon}"></i>
              </span>
              <span class="ps-cat-right">
                <span class="ps-cat-label">${escapeHtml(c.label)}</span>
              </span>
            `;
            frag.appendChild(b);
          }

          const actions = document.createElement("div");
          actions.className = "ps-filter-actions";
          actions.innerHTML = `
            <button type="button" class="ps-filter-action-btn ps-filter-action-clear">Clear all</button>
            <button type="button" class="ps-filter-action-btn ps-filter-action-apply">Apply filters</button>
          `;
          frag.appendChild(actions);

          filterInner.appendChild(frag);
        }

        function openFilterBox() {
          hideSearchResults();
          draftCategoryKeys = [...selectedCategoryKeys];
          renderCategoryBox();
          showFilter();
          updateHintVisibility();
        }

        function closeFilterBox() {
          hideFilter();
        }

        function toggleDraftCategory(key) {
          if (!key) return;

          if (draftCategoryKeys.includes(key)) {
            draftCategoryKeys = draftCategoryKeys.filter((k) => k !== key);
          } else {
            draftCategoryKeys = sortCategoryKeys([...draftCategoryKeys, key]);
          }

          renderCategoryBox();
        }

        function applyDraftCategories({ close = true } = {}) {
          const nextKeys = sortCategoryKeys(draftCategoryKeys);
          const changed = !arraysEqual(selectedCategoryKeys, nextKeys);

          selectedCategoryKeys = nextKeys;
          persistCategorySelection();
          updateFilterButtonState();

          if (close) closeFilterBox();

          if (changed) {
            if (!box.hidden) doSuggestSearch();
            if (isHomeResultsMode()) runHomeResultsSearch();
          }

          updateHintVisibility();
        }

        filterInner.addEventListener("click", (e) => {
          e.stopPropagation();

          const categoryBtn = e.target.closest("button.ps-cat-pill");
          if (categoryBtn) {
            toggleDraftCategory(categoryBtn.dataset.key);
            return;
          }

          const clearAllBtn = e.target.closest("button.ps-filter-action-clear");
          if (clearAllBtn) {
            draftCategoryKeys = [];
            applyDraftCategories({ close: true });
            return;
          }

          const applyBtn = e.target.closest("button.ps-filter-action-apply");
          if (applyBtn) {
            applyDraftCategories({ close: true });
          }
        });

        filterBtn.addEventListener("click", (e) => {
          e.stopPropagation();

          if (!filterBox.hidden) {
            closeFilterBox();
          } else {
            openFilterBox();
          }

          updateHintVisibility();
        });

        restoreCategorySelection();

        const pathNow = location.pathname || "/";
        const urlJur = /^\/uk\//i.test(pathNow) ? "uk" : /^\/us\//i.test(pathNow) ? "us" : null;

        let preferredJur =
          urlJur ||
          (["uk", "us"].includes(localStorage.getItem("ps_jurisdiction"))
            ? localStorage.getItem("ps_jurisdiction")
            : "us");

        window.addEventListener("ps:jurisdiction", (e) => {
          const j = e?.detail;
          if (j === "uk" || j === "us") {
            preferredJur = j;
            if (!box.hidden) doSuggestSearch();
            if (isHomeResultsMode()) runHomeResultsSearch();
          }
        });

        const SESSION_SHOW = "ps_show_results";
        const SESSION_QUERY = "ps_results_query";

        function setHomeResultsMode(q) {
          sessionStorage.setItem(SESSION_SHOW, "1");
          sessionStorage.setItem(SESSION_QUERY, q || "");
        }

        function clearHomeResultsMode() {
          sessionStorage.removeItem(SESSION_SHOW);
          sessionStorage.removeItem(SESSION_QUERY);
        }

        function isHomeResultsMode() {
          return pageType === "home" && sessionStorage.getItem(SESSION_SHOW) === "1";
        }

        function getHomeResultsQuery() {
          return sessionStorage.getItem(SESSION_QUERY) || "";
        }

        function showHomePanel() {
          if (!homePanel) return;

          if (homeClear) {
            homeClear.hidden = false;
          }

          homePanel.hidden = false;
          updateHintVisibility();
        }

        function hideHomePanel() {
          if (!homePanel) return;

          homePanel.hidden = true;

          if (homeList) homeList.innerHTML = "";
          if (homeTitle) homeTitle.textContent = "";

          if (homeClear) {
            homeClear.hidden = true;
          }

          updateHintVisibility();
        }

        inner.addEventListener("click", (e) => {
          const b = e.target.closest("button.ps-result-btn");
          if (!b) return;
          dismissKeyboard();
          const href = b.dataset.href;
          if (href) location.href = href;
        });

        inner.addEventListener("keydown", (e) => {
          const b = e.target.closest("button.ps-result-btn");
          if (!b) return;

          const btns = getResultButtons();
          const idx = btns.indexOf(b);

          if (e.key === "ArrowDown") { e.preventDefault(); focusResultAt(idx + 1); return; }
          if (e.key === "ArrowUp")   { e.preventDefault(); focusResultAt(idx - 1); return; }

          if (e.key === "Escape") {
            e.preventDefault();
            hideSearchResults();
            input.focus();
            return;
          }

          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            dismissKeyboard();
            const href = b.dataset.href;
            if (href) location.href = href;
          }
        });

        function renderSuggestionResults(results, q) {
          activeIndex = -1;
          inner.innerHTML = "";

          if (!results.length) {
            inner.innerHTML = `<div class="ps-no-results">No matches for “${escapeHtml(q)}”.</div>`;
            showSearchResults();
            return;
          }

          const frag = document.createDocumentFragment();

          for (const r of results) {
            const b = document.createElement("button");
            b.type = "button";
            b.className = "ps-result-btn";
            b.setAttribute("role", "option");
            b.dataset.href = r.url;

            const t = document.createElement("div");
            t.className = "ps-result-title";

            const displayTitle = (r.meta?.title || r.title || "")
              .replace(/^What to do if…\s*/i, "")
              .trim();

            t.textContent = displayTitle;

            b.appendChild(t);
            frag.appendChild(b);
          }

          inner.appendChild(frag);
          showSearchResults();
        }

        async function doSuggestSearch() {
          const q = norm(input.value);
          updateHintVisibility();
          updateClearVisibility();

          if (!q || q.length < 2) { hideSearchResults(); return; }

          const pagefind = await ensurePagefind();

          const filters = { jurisdiction: preferredJur };
          if (selectedCategoryKeys.length) {
            filters.category = {
              any: selectedCategoryKeys
                .map((key) => CATEGORY_FULL[key])
                .filter(Boolean)
            };
          }

          const search = await pagefind.search(q, { filters });

          const items = [];
          for (const r of search.results.slice(0, 12)) {
            const data = await r.data();
            items.push(data);
          }

          renderSuggestionResults(items, q);
        }

        let t = null;
        input.addEventListener("input", () => {
          hideHomePanel();
          clearTimeout(t);
          t = setTimeout(doSuggestSearch, 90);
          updateHintVisibility();
          updateClearVisibility();
        });

        input.addEventListener("focus", () => { updateHintVisibility(); updateClearVisibility(); });
        input.addEventListener("blur",  () => { updateHintVisibility(); updateClearVisibility(); });

        function buildFiltersForSearch() {
          const filters = { jurisdiction: preferredJur };
          if (selectedCategoryKeys.length) {
            filters.category = {
              any: selectedCategoryKeys
                .map((key) => CATEGORY_FULL[key])
                .filter(Boolean)
            };
          }
          return filters;
        }

        function extractFullCategoryFromResultData(data) {
          const maybe = data?.filters?.category;
          if (Array.isArray(maybe) && maybe.length) return maybe[0];
          return null;
        }

        function renderHomeResults(items, rawQuery) {
          if (!homePanel || !homeList || !homeTitle) return;

          homeList.innerHTML = "";

          const qLabel = (rawQuery || "").trim();
          const filtersLabel = selectedCategoryKeys.length
            ? ` • ${escapeHtml(
                selectedCategoryKeys
                  .map((key) => CATEGORIES.find((c) => c.key === key)?.label)
                  .filter(Boolean)
                  .join(", ")
              )}`
            : "";

          homeTitle.innerHTML = qLabel
            ? `Results for “${escapeHtml(qLabel)}”${filtersLabel}`
            : `Results${filtersLabel}`;

          if (!items.length) {
            homeList.innerHTML = `<div class="ps-home-empty">No matches.</div>`;
            showHomePanel();
            return;
          }

          const frag = document.createDocumentFragment();

          for (const data of items) {
            const url = data?.url;
            const title = (data?.meta?.title || data?.title || "")
              .replace(/^What to do if…\s*/i, "")
              .trim();

            const fullCat = extractFullCategoryFromResultData(data);
            const icon = fullCat ? (ICON_BY_FULL_CATEGORY.get(fullCat) || "fa-file-lines") : "fa-file-lines";

            const b = document.createElement("button");
            b.type = "button";
            b.className = "ps-home-result-btn";
            b.dataset.href = url || "";

            b.innerHTML = `
              <span class="ps-home-result-icon" aria-hidden="true">
                <i class="fa-solid ${icon}"></i>
              </span>
              <span class="ps-home-result-title">${escapeHtml(title || "Untitled")}</span>
            `;

            frag.appendChild(b);
          }

          homeList.appendChild(frag);
          showHomePanel();
        }

        if (homeList) {
          homeList.addEventListener("click", (e) => {
            const b = e.target.closest("button.ps-home-result-btn");
            if (!b) return;
            dismissKeyboard();
            const href = b.dataset.href;
            if (href) location.href = href;
          });

          homeList.addEventListener("keydown", (e) => {
            if (e.key !== "Enter" && e.key !== " ") return;
            const b = e.target.closest("button.ps-home-result-btn");
            if (!b) return;
            e.preventDefault();
            dismissKeyboard();
            const href = b.dataset.href;
            if (href) location.href = href;
          });
        }

        async function runHomeResultsSearch() {
          if (pageType !== "home") return;

          const q = getHomeResultsQuery();
          const hasFilters = selectedCategoryKeys.length > 0;

          if ((!q || norm(q).length < 2) && !hasFilters) {
            clearHomeResultsMode();
            hideHomePanel();
            return;
          }

          if (!q || norm(q).length < 2) {
            clearHomeResultsMode();
            hideHomePanel();
            return;
          }

          const pagefind = await ensurePagefind();
          const filters = buildFiltersForSearch();

          const search = await pagefind.search(norm(q), { filters });

          const items = [];
          for (const r of search.results.slice(0, 25)) {
            const data = await r.data();
            items.push(data);
          }

          renderHomeResults(items, q);
        }

        async function triggerFullSearchFromInput() {
          hideSearchResults();
          hideFilter();

          const raw = input.value || "";
          const q = raw.trim();

          dismissKeyboard();

          input.value = "";
          updateClearVisibility();

          persistCategorySelection();

          if (!q || norm(q).length < 2) {
            clearHomeResultsMode();

            if (pageType !== "home") {
              location.href = "/";
              return;
            }

            hideHomePanel();
            updateHintVisibility();
            return;
          }

          setHomeResultsMode(q);

          if (pageType !== "home") {
            location.href = "/";
            return;
          }

          await runHomeResultsSearch();
          updateHintVisibility();
        }

        searchBtn.addEventListener("click", () => {
          dismissKeyboard();
          triggerFullSearchFromInput();
        });

        input.addEventListener("keydown", (e) => {
          if (e.key === "Escape") { hideSearchResults(); hideFilter(); return; }

          if (e.key === "ArrowDown") {
            if (!box.hidden) {
              e.preventDefault();
              hideFilter();
              focusResultAt(0);
            }
            return;
          }

          if (e.key === "ArrowUp") {
            if (!box.hidden) {
              e.preventDefault();
              hideFilter();
              const btns = getResultButtons();
              focusResultAt(btns.length - 1);
            }
            return;
          }

          if (e.key === "Enter") {
            e.preventDefault();
            triggerFullSearchFromInput();
            return;
          }
        });

        if (homeClear) {
          homeClear.addEventListener("click", () => {
            clearHomeResultsMode();
            hideHomePanel();
            input.focus();
            updateHintVisibility();
            updateClearVisibility();
          });
        }

        if (pageType === "home" && sessionStorage.getItem(SESSION_SHOW) === "1") {
          const savedQuery = norm(getHomeResultsQuery());
          const hasFilters = selectedCategoryKeys.length > 0;

          if (savedQuery.length >= 2 || hasFilters) {
            runHomeResultsSearch();
          } else {
            clearHomeResultsMode();
            hideHomePanel();
          }
        }

        document.addEventListener("click", (e) => {
          const clickedSearch =
            e.target.closest("#ps-search-results") ||
            e.target.closest("#ps-search") ||
            e.target.closest("#ps-search-btn") ||
            e.target.closest("#ps-clear-btn");

          const clickedFilter =
            e.target.closest("#ps-filter-box") ||
            e.target.closest("#ps-filter-btn");

          if (!clickedSearch) hideSearchResults();

          if (!clickedFilter) {
            if (!filterBox.hidden) {
              applyDraftCategories({ close: true });
            } else {
              hideFilter();
            }
          }

          updateHintVisibility();
          updateClearVisibility();
        });

        updateFilterButtonState();
        updateHintVisibility();
        updateClearVisibility();
      }
    </script>
  </body>
</html>

