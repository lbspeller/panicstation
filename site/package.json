{
  "name": "site",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "redirects:build": "node scripts/build-redirect-function.mjs",
    "dev": "npm run redirects:build && npm run cache:clear && astro dev",
    "build": "npm run redirects:build && npm run cache:clear && astro build",
    "postbuild": "node scripts/apply-resource-titles-to-dist.mjs && pagefind --site dist",
    "preview": "astro preview",
    "cache:clear": "node scripts/clear-astro-cache.mjs"
  },
  "dependencies": {
    "astro": "^5.17.1"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.0",
    "pagefind": "^1.4.0"
  }
}
